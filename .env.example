# Copy this file to .env and edit the values.

# Required for scripts that call DeepSeek API.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override DeepSeek API endpoint (default: https://api.deepseek.com).
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local Qwen3-8B model path.
QWEN3_MODEL_PATH=./models/Qwen3-8B

# Dataset directory.
# - Use data/deepseek_hard for full reproduction (generate data via DeepSeek API).
# - Use data_deepseek_hard to verify the released LoRA with the official dataset.
DATA_DIR=data/deepseek_hard

# Keep 1 for offline/local model loading.
# Set to 0 only if you want Transformers to try downloading missing files.
HF_LOCAL_FILES_ONLY=1