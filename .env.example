# Copy this file to .env and edit the values.

# Required for scripts that call DeepSeek API.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Local Qwen3-8B model path on Windows.
# Example:
# QWEN3_MODEL_PATH=D:\models\Qwen3-8B
QWEN3_MODEL_PATH=D:\models\Qwen3-8B

# Default dataset directory used by this project.
DATA_DIR=data_deepseek_hard

# Keep 1 for offline/local model loading.
# Set to 0 only if you want Transformers to try downloading missing files.
HF_LOCAL_FILES_ONLY=1